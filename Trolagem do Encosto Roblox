            return
        end

        -- Verificar CreateWindow
        if not Rayfield.CreateWindow then
            setStatus("ERRO: CreateWindow nao existe!", Color3.fromRGB(255, 50, 50))
            openBtn.Text = "ERRO - API"
            return
        end

        -- CRIAR JANELA
        local okW, Window = pcall(function()
            return Rayfield:CreateWindow({
                Name = "Delta v10.2",
                LoadingTitle = "Delta v10.2",
                LoadingSubtitle = "Carregando...",
                ConfigurationSaving = {Enabled = false},
                Discord = {Enabled = false},
                KeySystem = false,
            })
        end)

        if not okW or not Window then
            setStatus("ERRO ao criar janela: " .. tostring(Window), Color3.fromRGB(255, 50, 50))
            openBtn.Text = "ERRO - Janela"
            return
        end

        setStatus("Janela criada! Criando abas...", Color3.fromRGB(0, 255, 100))
        task.wait(0.3)

        -- Helper para valor de dropdown
        local function getDV(o)
            if type(o) == "table" then return o[1] end
            return o
        end

        -- ============ ABA SEGUIR ============
        pcall(function()
            local tab = Window:CreateTab("Seguir", 4483362458)
            task.wait(0.1)

            pcall(function() tab:CreateSection("Selecionar Player") end)

            pcall(function()
                tab:CreateDropdown({
                    Name = "Escolher Player",
                    Options = getListaPlayers(),
                    CurrentOption = {"Nenhum"},
                    MultipleOptions = false,
                    Flag = "DropSeguir",
                    Callback = function(o)
                        local v = getDV(o)
                        if v and v ~= "Nenhum" then local p = getPlayerByName(v); if p then marcarPlayerSelecionado(p) end end
                    end,
                })
            end)

            pcall(function()
                tab:CreateInput({
                    Name = "Digitar Nome",
                    PlaceholderText = "Nome do player...",
                    RemoveTextAfterFocusLost = false,
                    Flag = "InputPlayer",
                    Callback = function(t) if t and t ~= "" then selecionarPlayer(t) end end,
                })
            end)

            pcall(function() tab:CreateSection("Modo de Seguir") end)

            pcall(function()
                tab:CreateDropdown({
                    Name = "Modo",
                    Options = {"Normal", "Pathfinding", "Encosto"},
                    CurrentOption = {"Normal"},
                    MultipleOptions = false,
                    Flag = "DropModo",
                    Callback = function(o)
                        local modo = getDV(o)
                        if modo == "Encosto" then modoSeguir = "encosto"
                        elseif modo == "Pathfinding" then modoSeguir = "pathfinding"
                        else modoSeguir = "normal" end
                    end,
                })
            end)

            pcall(function() tab:CreateSection("Acoes") end)

            pcall(function()
                tab:CreateButton({
                    Name = "SEGUIR",
                    Callback = function()
                        local nome = playerSelecionadoNome
                        pcall(function()
                            local f = Rayfield.Flags
                            if f and f.DropSeguir then
                                local opt = f.DropSeguir.CurrentOption
                                local v = getDV(opt)
                                if v and v ~= "Nenhum" then nome = v end
                            end
                        end)
                        if not nome or nome == "Nenhum" then safeNotify("Erro", "Selecione um player!"); return end
                        local p = getPlayerByName(nome)
                        if p then iniciarSeguir(p) else safeNotify("Erro", nome .. " nao encontrado!") end
                    end,
                })
            end)

            pcall(function()
                tab:CreateButton({
                    Name = "PARAR",
                    Callback = function() if seguindo then pararSeguir() else safeNotify("Info", "Nao esta seguindo!") end end,
                })
            end)

            pcall(function() tab:CreateSection("Extras") end)

            pcall(function()
                tab:CreateToggle({
                    Name = "Seguir ao Encostar",
                    CurrentValue = false,
                    Flag = "ToggleToque",
                    Callback = function(v) if v then ativarSelecaoPorToque() else desativarSelecaoPorToque() end end,
                })
            end)

            addLog("Aba Seguir criada", "UI")
        end)

        task.wait(0.1)

        -- ============ ABA CLONES ============
        pcall(function()
            local tab = Window:CreateTab("Clones", 4483362458)
            task.wait(0.1)

            pcall(function() tab:CreateSection("Alvo dos Clones") end)

            pcall(function()
                tab:CreateDropdown({
                    Name = "Alvo",
                    Options = getListaPlayers(),
                    CurrentOption = {"Nenhum"},
                    MultipleOptions = false,
                    Flag = "DropCloneAlvo",
                    Callback = function(o)
                        local v = getDV(o)
                        if v and v ~= "Nenhum" then local p = getPlayerByName(v); if p then cloneAlvo = p; cloneAlvoNome = p.Name; marcarPlayerSelecionado(p) end end
                    end,
                })
            end)

            local function getCloneAlvo()
                local a = cloneAlvo
                if not a and playerSelecionadoNome then a = getPlayerByName(playerSelecionadoNome) end
                if not a and playerAlvo then a = playerAlvo end
                return a
            end

            pcall(function() tab:CreateSection("Adicionar Clones") end)
            pcall(function() tab:CreateButton({Name = "+1 Clone", Callback = function() local a = getCloneAlvo(); if a then adicionarClones(1, a) else safeNotify("Erro", "Selecione alvo!") end end}) end)
            pcall(function() tab:CreateButton({Name = "+3 Clones", Callback = function() local a = getCloneAlvo(); if a then adicionarClones(3, a) else safeNotify("Erro", "Selecione alvo!") end end}) end)
            pcall(function() tab:CreateButton({Name = "+5 Clones", Callback = function() local a = getCloneAlvo(); if a then adicionarClones(5, a) else safeNotify("Erro", "Selecione alvo!") end end}) end)
            pcall(function() tab:CreateButton({Name = "+10 Clones", Callback = function() local a = getCloneAlvo(); if a then adicionarClones(10, a) else safeNotify("Erro", "Selecione alvo!") end end}) end)

            pcall(function() tab:CreateSection("Gerenciar") end)
            pcall(function() tab:CreateButton({Name = "Redirecionar", Callback = function() local a = getCloneAlvo(); if a then redirecionarClones(a) else safeNotify("Erro", "Selecione alvo!") end end}) end)
            pcall(function() tab:CreateButton({Name = "Remover TODOS", Callback = function() removerTodosClones() end}) end)

            pcall(function() tab:CreateSection("Config Clones") end)
            pcall(function() tab:CreateSlider({Name = "Velocidade", Range = {10, 100}, Increment = 2, Suffix = " speed", CurrentValue = 22, Flag = "SliderCloneSpeed", Callback = function(v) cloneVelocidade = v end}) end)
            pcall(function() tab:CreateSlider({Name = "Distancia", Range = {2, 20}, Increment = 0.5, Suffix = " studs", CurrentValue = 5, Flag = "SliderCloneDist", Callback = function(v) cloneDistancia = v end}) end)
            pcall(function() tab:CreateSlider({Name = "Raio Spawn", Range = {5, 50}, Increment = 1, Suffix = " studs", CurrentValue = 15, Flag = "SliderCloneRaio", Callback = function(v) cloneSpawnRaio = v end}) end)

            addLog("Aba Clones criada", "UI")
        end)

        task.wait(0.1)

        -- ============ ABA FUGIR ============
        pcall(function()
            local tab = Window:CreateTab("Fugir", 4483362458)
            task.wait(0.1)

            pcall(function() tab:CreateSection("Fugir de quem?") end)

            pcall(function()
                tab:CreateDropdown({
                    Name = "Perseguidor",
                    Options = getListaPlayers(),
                    CurrentOption = {"Nenhum"},
                    MultipleOptions = false,
                    Flag = "DropFugir",
                    Callback = function(o)
                        local v = getDV(o)
                        if v and v ~= "Nenhum" then local p = getPlayerByName(v); if p then marcarPlayerSelecionado(p) end end
                    end,
                })
            end)

            pcall(function() tab:CreateSection("Acoes") end)
            pcall(function()
                tab:CreateButton({
                    Name = "FUGIR!",
                    Callback = function()
                        local nome = playerSelecionadoNome
                        pcall(function()
                            local f = Rayfield.Flags; if f and f.DropFugir then
                                local v = getDV(f.DropFugir.CurrentOption)
                                if v and v ~= "Nenhum" then nome = v end
                            end
                        end)
                        if not nome or nome == "Nenhum" then safeNotify("Erro", "Selecione perseguidor!"); return end
                        local p = getPlayerByName(nome)
                        if p then iniciarFugir(p) else safeNotify("Erro", nome .. " nao encontrado!") end
                    end,
                })
            end)
            pcall(function() tab:CreateButton({Name = "PARAR DE FUGIR", Callback = function() if fugindo then pararFugir() else safeNotify("Info", "Nao esta fugindo!") end end}) end)

            pcall(function() tab:CreateSection("Config Fuga") end)
            pcall(function() tab:CreateSlider({Name = "Dist Minima", Range = {3, 20}, Increment = 1, Suffix = " studs", CurrentValue = 8, Flag = "SliderDistMin", Callback = function(v) fugirDistanciaMinima = v end}) end)
            pcall(function() tab:CreateSlider({Name = "Dist Segura", Range = {15, 80}, Increment = 5, Suffix = " studs", CurrentValue = 30, Flag = "SliderFugirDist", Callback = function(v) fugirDistanciaSegura = v end}) end)

            addLog("Aba Fugir criada", "UI")
        end)

        task.wait(0.1)

        -- ============ ABA ANIM ============
        pcall(function()
            local tab = Window:CreateTab("Anim", 4483362458)
            task.wait(0.1)

            pcall(function() tab:CreateSection("Andar") end)
            local na = {}; for _, a in ipairs(ANIMS_ANDAR) do table.insert(na, a.nome) end
            pcall(function()
                tab:CreateDropdown({
                    Name = "Estilo de Andar",
                    Options = na,
                    CurrentOption = {ANIMS_ANDAR[1].nome},
                    MultipleOptions = false,
                    Flag = "DropAndar",
                    Callback = function(o)
                        local v = getDV(o)
                        for i, a in ipairs(ANIMS_ANDAR) do
                            if a.nome == v then animAndarAtual = i; if animAndarTrack then pcall(function() animAndarTrack:Stop(0) end); animAndarTrack = nil end; break end
                        end
                    end,
                })
            end)

            pcall(function() tab:CreateSection("Danca") end)
            pcall(function() tab:CreateToggle({Name = "Dancar quando alvo para", CurrentValue = true, Flag = "ToggleDancar", Callback = function(v) dancarAoParar = v; if not v and estaDancando then pararDanca() end end}) end)

            local nd = {}; for _, d in ipairs(DANCAS) do table.insert(nd, d.nome) end
            pcall(function()
                tab:CreateDropdown({
                    Name = "Escolher Danca",
                    Options = nd,
                    CurrentOption = {DANCAS[1].nome},
                    MultipleOptions = false,
                    Flag = "DropDanca",
                    Callback = function(o)
                        local v = getDV(o)
                        for i, d in ipairs(DANCAS) do
                            if d.nome == v then animDancaAtual = i; if estaDancando then pararDanca(); task.spawn(function() task.wait(0.15); iniciarDanca(true) end) end; break end
                        end
                    end,
                })
            end)

            pcall(function() tab:CreateSection("Testar") end)
            pcall(function() tab:CreateButton({Name = "Dancar Agora!", Callback = function() dancaCancelada = false; task.spawn(function() iniciarDanca(true) end) end}) end)
            pcall(function() tab:CreateButton({Name = "Parar Animacoes", Callback = function() pararTodasAnimacoes() end}) end)

            addLog("Aba Anim criada", "UI")
        end)

        task.wait(0.1)

        -- ============ ABA CONFIG ============
        pcall(function()
            local tab = Window:CreateTab("Config", 4483362458)
            task.wait(0.1)

            pcall(function() tab:CreateSection("Distancia") end)
            pcall(function() tab:CreateSlider({Name = "Distancia do Alvo", Range = {1, 20}, Increment = 0.5, Suffix = " studs", CurrentValue = 3, Flag = "SliderDist", Callback = function(v) distanciaSeguir = v end}) end)

            pcall(function() tab:CreateSection("Speed Hack") end)
            pcall(function() tab:CreateToggle({Name = "Speed Hack", CurrentValue = false, Flag = "ToggleSpeed", Callback = function(v) setSpeed(v, speedValor) end}) end)
            pcall(function() tab:CreateSlider({Name = "Velocidade", Range = {16, 200}, Increment = 2, Suffix = "", CurrentValue = 50, Flag = "SliderSpeed", Callback = function(v) speedValor = v; if speedAtivo then setSpeed(true, v) end end}) end)

            pcall(function() tab:CreateSection("Invisibilidade") end)
            pcall(function()
                tab:CreateToggle({
                    Name = "Invisivel ao Seguir",
                    CurrentValue = false,
                    Flag = "ToggleInvis",
                    Callback = function(v)
                        modoInvisivel = v
                        if not v and LocalPlayer.Character then
                            pcall(function()
                                for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then part.Transparency = 0
                                    elseif part:IsA("Decal") or part:IsA("Texture") then part.Transparency = 0 end
                                end
                            end)
                        end
                    end,
                })
            end)

            addLog("Aba Config criada", "UI")
        end)

        task.wait(0.1)

        -- ============ ABA TP ============
        pcall(function()
            local tab = Window:CreateTab("TP", 4483362458)
            task.wait(0.1)

            pcall(function() tab:CreateSection("Teleporte") end)
            pcall(function()
                tab:CreateDropdown({
                    Name = "Player",
                    Options = getListaPlayers(),
                    CurrentOption = {"Nenhum"},
                    MultipleOptions = false,
                    Flag = "DropTP",
                    Callback = function(o) local v = getDV(o); if v and v ~= "Nenhum" then local p = getPlayerByName(v); if p then marcarPlayerSelecionado(p) end end end,
                })
            end)
            pcall(function()
                tab:CreateButton({
                    Name = "Teleportar",
                    Callback = function()
                        local nome = playerSelecionadoNome
                        pcall(function() local f = Rayfield.Flags; if f and f.DropTP then local v = getDV(f.DropTP.CurrentOption); if v and v ~= "Nenhum" then nome = v end end end)
                        if nome and nome ~= "Nenhum" then teleportarParaPlayer(nome) else safeNotify("Erro", "Selecione player!") end
                    end,
                })
            end)
            pcall(function()
                tab:CreateButton({
                    Name = "TP + Seguir",
                    Callback = function()
                        local nome = playerSelecionadoNome
                        pcall(function() local f = Rayfield.Flags; if f and f.DropTP then local v = getDV(f.DropTP.CurrentOption); if v and v ~= "Nenhum" then nome = v end end end)
                        if nome and nome ~= "Nenhum" then local p = getPlayerByName(nome); if p then teleportarParaPlayer(nome); task.wait(0.3); iniciarSeguir(p) end
                        else safeNotify("Erro", "Selecione player!") end
                    end,
                })
            end)

            addLog("Aba TP criada", "UI")
        end)

        task.wait(0.1)

        -- ============ ABA GERAL ============
        pcall(function()
            local tab = Window:CreateTab("Geral", 4483362458)
            task.wait(0.1)

            pcall(function() tab:CreateSection("Controle") end)
            pcall(function() tab:CreateButton({Name = "PARAR TUDO", Callback = function() removerTodosClones(); pararTudo() end}) end)
            pcall(function()
                tab:CreateButton({
                    Name = "Atualizar Lista",
                    Callback = function()
                        local lista = getListaPlayers()
                        for _, d in ipairs({"DropSeguir", "DropTP", "DropFugir", "DropCloneAlvo"}) do
                            pcall(function() local f = Rayfield.Flags; if f and f[d] then f[d]:Refresh(lista) end end)
                        end
                        safeNotify("Atualizado", #lista - 1 .. " players")
                    end,
                })
            end)

            addLog("Aba Geral criada", "UI")
        end)

        -- ============ EVENTOS ============
        pcall(function()
            Players.PlayerRemoving:Connect(function(player)
                if playerAlvo and playerAlvo == player then pararSeguir() end
                if playerPerseguidor and playerPerseguidor == player then pararFugir() end
                if cloneAlvo and cloneAlvo == player then removerTodosClones(); cloneAlvo = nil end
                task.wait(1)
                local lista = getListaPlayers()
                for _, d in ipairs({"DropSeguir", "DropTP", "DropFugir", "DropCloneAlvo"}) do
                    pcall(function() local f = Rayfield.Flags; if f and f[d] then f[d]:Refresh(lista) end end)
                end
            end)

            Players.PlayerAdded:Connect(function()
                task.wait(2)
                local lista = getListaPlayers()
                for _, d in ipairs({"DropSeguir", "DropTP", "DropFugir", "DropCloneAlvo"}) do
                    pcall(function() local f = Rayfield.Flags; if f and f[d] then f[d]:Refresh(lista) end end)
                end
            end)

            LocalPlayer.CharacterAdded:Connect(function()
                animSentadoTrack = nil; animAndarTrack = nil; animDancaTrack = nil; estaDancando = false
                desativarFantasma()
                if seguindo then task.wait(2); if playerAlvo and getRootPart(playerAlvo) then iniciarSeguir(playerAlvo) else pararSeguir() end end
                if fugindo then task.wait(2); if playerPerseguidor and getRootPart(playerPerseguidor) then iniciarFugir(playerPerseguidor) else pararFugir() end end
                if speedAtivo and not fugindo then task.wait(1); local h = getHumanoid(LocalPlayer); if h then h.WalkSpeed = speedValor end end
            end)
        end)

        -- SUCESSO! Esconder launcher
        setStatus("Menu aberto!", Color3.fromRGB(0, 255, 100))
        task.wait(1)
        pcall(function() mainFrame.Visible = false end)

        safeNotify("Delta v10.2", "Menu carregado com sucesso!")
        addLog("=== DELTA v10.2 CARREGADO ===", "OK")
    end)
end)

print("[DELTA v10.2] Tela inicial criada - clique em ABRIR MENU")