    if not a then a = Instance.new("Animator"); a.Parent = h end
    local anim = Instance.new("Animation"); anim.AnimationId = animId
    local track = nil
    pcall(function() track = a:LoadAnimation(anim) end)
    if track then track.Looped = looped or false; track.Priority = Enum.AnimationPriority.Action4; track:Play(fadeIn or 0.2) end
