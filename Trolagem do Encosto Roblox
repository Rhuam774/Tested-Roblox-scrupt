        p.Parent = model
        if shape then p.Shape = shape end
        parts[name] = p
        return p
    end

    local hrp = mk("HumanoidRootPart", Vector3.new(2, 2, 1), Color3.new(0.5, 0.5, 0.5))
    hrp.Transparency = 1
    hrp.CanCollide = false

    mk("LowerTorso", Vector3.new(2, 2, 1), tr_c)
    mk("UpperTorso", Vector3.new(2, 2, 1), tr_c)
    mk("Head", Vector3.new(2, 1, 1), sk, Enum.PartType.Ball)
    mk("RightUpperArm", Vector3.new(1, 2, 1), sk)
    mk("RightLowerArm", Vector3.new(1, 2, 1), sk)
    mk("RightHand", Vector3.new(1, 1, 2), sk)
    mk("LeftUpperArm", Vector3.new(1, 2, 1), sk)
    mk("LeftLowerArm", Vector3.new(1, 2, 1), sk)
    mk("LeftHand", Vector3.new(1, 1, 2), sk)
    mk("RightUpperLeg", Vector3.new(1, 2, 1), lg)
    mk("RightLowerLeg", Vector3.new(1, 2, 1), lg)
    mk("RightFoot", Vector3.new(1, 1, 2), lg)
    mk("LeftUpperLeg", Vector3.new(1, 2, 1), lg)
    mk("LeftLowerLeg", Vector3.new(1, 2, 1), lg)
    mk("LeftFoot", Vector3.new(1, 1, 2), lg)

    -- ============================================================
    -- MOTOR6D JOINTS (sem pcalls - direto)
    -- ============================================================
    local function mm(name, p0n, p1n, c0, c1)
        local p0 = parts[p0n]; local p1 = parts[p1n]
        if not p0 or not p1 then return end
        local m = Instance.new("Motor6D")
        m.Name = name
        m.Part0 = p0
        m.Part1 = p1
        m.C0 = c0
        m.C1 = c1
        m.Parent = p1
    end

    mm("Root", "HumanoidRootPart", "LowerTorso", CFrame.new(0, 0, 0), CFrame.new(0, -0.5, 0))
    mm("Waist", "LowerTorso", "UpperTorso", CFrame.new(0, 1, 0), CFrame.new(0, -1, 0))
    mm("Neck", "UpperTorso", "Head", CFrame.new(0, 1, 0), CFrame.new(0, -0.5, 0))
    mm("RightShoulder", "UpperTorso", "RightUpperArm", CFrame.new(1.5, 0.5, 0), CFrame.new(-0.5, 0.5, 0))
    mm("RightElbow", "RightUpperArm", "RightLowerArm", CFrame.new(0, -1, 0), CFrame.new(0, 1, 0))
    mm("RightWrist", "RightLowerArm", "RightHand", CFrame.new(0, -1, 0), CFrame.new(0, 0.5, 0))
    mm("LeftShoulder", "UpperTorso", "LeftUpperArm", CFrame.new(-1.5, 0.5, 0), CFrame.new(0.5, 0.5, 0))
    mm("LeftElbow", "LeftUpperArm", "LeftLowerArm", CFrame.new(0, -1, 0), CFrame.new(0, 1, 0))
    mm("LeftWrist", "LeftLowerArm", "LeftHand", CFrame.new(0, -1, 0), CFrame.new(0, 0.5, 0))
    mm("RightHip", "LowerTorso", "RightUpperLeg", CFrame.new(0.5, -1, 0), CFrame.new(0, 1, 0))
    mm("RightKnee", "RightUpperLeg", "RightLowerLeg", CFrame.new(0, -1, 0), CFrame.new(0, 1, 0))
    mm("RightAnkle", "RightLowerLeg", "RightFoot", CFrame.new(0, -1, 0), CFrame.new(0, 0.5, 0))
    mm("LeftHip", "LowerTorso", "LeftUpperLeg", CFrame.new(-0.5, -1, 0), CFrame.new(0, 1, 0))
    mm("LeftKnee", "LeftUpperLeg", "LeftLowerLeg", CFrame.new(0, -1, 0), CFrame.new(0, 1, 0))
    mm("LeftAnkle", "LeftLowerLeg", "LeftFoot", CFrame.new(0, -1, 0), CFrame.new(0, 0.5, 0))

    -- Humanoid
    local hum = Instance.new("Humanoid")
    hum.MaxHealth = 99999; hum.Health = 99999
    hum.WalkSpeed = cloneVelocidade
    hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    hum.NameDisplayDistance = 0; hum.HealthDisplayDistance = 0
    hum.BreakJointsOnDeath = false
    hum.Parent = model
    hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    hum:ChangeState(Enum.HumanoidStateType.Running)

    Instance.new("Animator").Parent = hum
    model.PrimaryPart = hrp

    -- Roupa
    if shirt then pcall(function() shirt:Clone().Parent = model end) end
    if pants then pcall(function() pants:Clone().Parent = model end) end

    -- ============================================================
    -- POSICIONAR (SEM RAYCAST - usar Y do player)
    -- ============================================================
    local angulo = (indice / math.max(totalNovos, 1)) * math.pi * 2
    local raio = math.random(5, cloneSpawnRaio)

    if alvoIsMe then
        -- Posicionar AO REDOR do player
        local offset = Vector3.new(math.cos(angulo) * cloneDistancia, 0, math.sin(angulo) * cloneDistancia)
        local pos = Vector3.new(meuRoot.Position.X + offset.X, meuRoot.Position.Y, meuRoot.Position.Z + offset.Z)
        hrp.CFrame = CFrame.new(pos, Vector3.new(meuRoot.Position.X, pos.Y, meuRoot.Position.Z))
        addLog("  Clone #" .. cid .. " perto de voce (Y=" .. string.format("%.0f", pos.Y) .. ")", "CLONE")
    else
        -- Posicionar perto do alvo
        local spawnX = meuRoot.Position.X + math.cos(angulo) * raio
        local spawnZ = meuRoot.Position.Z + math.sin(angulo) * raio
        local pos = Vector3.new(spawnX, meuRoot.Position.Y, spawnZ)
        hrp.CFrame = CFrame.new(pos, Vector3.new(alvoRoot.Position.X, pos.Y, alvoRoot.Position.Z))
        addLog("  Clone #" .. cid .. " spawn (Y=" .. string.format("%.0f", pos.Y) .. ")", "CLONE")
    end

    -- Pasta
    if not clonePasta or not clonePasta.Parent then
        clonePasta = Instance.new("Folder")
        clonePasta.Name = "DELTA_CLONES"
        clonePasta.Parent = Workspace
    end

    -- Parentar
    model.Parent = clonePasta

    -- Highlight
    local hl = Instance.new("Highlight")
    hl.Name = "DeltaCloneHL"
    hl.FillTransparency = 0.7
    hl.FillColor = Color3.fromRGB(0, 200, 255)
    hl.OutlineColor = Color3.fromRGB(0, 150, 255)
    hl.OutlineTransparency = 0
    hl.Parent = model

    local elapsed = string.format("%.2f", tick() - t0)
    addLog("  Clone #" .. cid .. " criado em " .. elapsed .. "s", "OK")

    -- ============================================================
    -- DESANCORAR (async)
    -- ============================================================
    local cd = {
        id = cid, modelo = model, conexao = nil,
        indiceRoda = 0, alvo = alvoPlayer, alvoIsMe = alvoIsMe,
        animAndarTrack = nil, animDancaTrack = nil, dancando = false,
        alvoUltimaPos = nil, alvoParadoTimer = 0, alvoEstaParado = false,
        prontoPraAndar = false,
    }

    task.delay(0.5, function()
        for _, part in pairs(model:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                part.CanCollide = true
            end
        end
        hum:ChangeState(Enum.HumanoidStateType.Running)
        task.wait(0.3)
        cd.prontoPraAndar = true
        addLog("Clone #" .. cid .. " PRONTO!", "OK")
    end)

    -- Indice na roda
    local totalAtual = 0
    for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then totalAtual = totalAtual + 1 end end
    cd.indiceRoda = totalAtual + 1

    -- ============================================================
    -- IA LOOP
    -- ============================================================
    cd.conexao = RunService.Heartbeat:Connect(function(dt)
        if not cd.modelo or not cd.modelo.Parent then
            if cd.conexao then cd.conexao:Disconnect(); cd.conexao = nil end
            return
        end
        local cRoot = cd.modelo:FindFirstChild("HumanoidRootPart")
        local cHum = cd.modelo:FindFirstChildOfClass("Humanoid")
        if not cRoot or not cHum then return end

        -- Manter vivo
        if cHum.Health < cHum.MaxHealth then cHum.Health = cHum.MaxHealth end
        local state = cHum:GetState()
        if state == Enum.HumanoidStateType.Dead or state == Enum.HumanoidStateType.Ragdoll then
            cHum:ChangeState(Enum.HumanoidStateType.Running)
        end

        if not cd.prontoPraAndar then return end

        -- ============================================================
        -- SEGUINDO VOCÊ (MoveTo simples)
        -- ============================================================
        if cd.alvoIsMe then
            local meuRoot2 = getRootPart(LocalPlayer)
            if not meuRoot2 then return end

            local dist = (cRoot.Position - meuRoot2.Position).Magnitude
            local myIdx = cd.indiceRoda
            local totalC = 0
            for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then totalC = totalC + 1 end end
            if totalC == 0 then totalC = 1 end

            -- Posição circular ao redor do player
            local angOff = (myIdx / totalC) * math.pi * 2
            local targetX = meuRoot2.Position.X + math.cos(angOff) * cloneDistancia
            local targetZ = meuRoot2.Position.Z + math.sin(angOff) * cloneDistancia
            local targetY = cRoot.Position.Y -- Manter Y atual
            local targetPos = Vector3.new(targetX, targetY, targetZ)

            cHum.WalkSpeed = cloneVelocidade

            -- Se muito longe, teleportar perto
            if dist > 50 then
                cRoot.CFrame = CFrame.new(
                    Vector3.new(meuRoot2.Position.X + math.cos(angOff) * cloneDistancia, meuRoot2.Position.Y, meuRoot2.Position.Z + math.sin(angOff) * cloneDistancia),
                    Vector3.new(meuRoot2.Position.X, meuRoot2.Position.Y, meuRoot2.Position.Z)
                )
                return
            end

            -- Usar MoveTo para andar
            cHum:MoveTo(targetPos)

            -- Olhar para o player
            local lookPos = Vector3.new(meuRoot2.Position.X, cRoot.Position.Y, meuRoot2.Position.Z)
            cRoot.CFrame = CFrame.new(cRoot.Position, lookPos)

            -- Dançar quando o player parar
            local tv = Vector3.new(0,0,0)
            pcall(function() tv = meuRoot2.AssemblyLinearVelocity or meuRoot2.Velocity or Vector3.new(0,0,0) end)
            local tvh = Vector3.new(tv.X, 0, tv.Z).Magnitude
            local th = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            local euMovo = th and th.MoveDirection.Magnitude > 0.1
            local euParado = tvh < 1 and not euMovo

            if cloneDancar and euParado and dist < cloneDistancia + 5 then
                if not cd.dancando then
                    if cd.animAndarTrack then cd.animAndarTrack:Stop(0); cd.animAndarTrack = nil end
                    -- Parar todas tracks do clone
                    pcall(function()
                        local a = cHum:FindFirstChildOfClass("Animator")
                        if a then for _, t in pairs(a:GetPlayingAnimationTracks()) do t:Stop(0) end end
                    end)
                    local dd = DANCAS[animDancaAtual]
                    if dd then
                        local anim = Instance.new("Animation"); anim.AnimationId = dd.id
                        local a = cHum:FindFirstChildOfClass("Animator")
                        if a then
                            local tr = a:LoadAnimation(anim)
                            if tr then
                                tr.Looped = true; tr.Priority = Enum.AnimationPriority.Action4
                                tr:Play(0.1); cd.animDancaTrack = tr; cd.dancando = true
                            end
                        end
                    end
                end
            else
                if cd.dancando then
                    if cd.animDancaTrack then cd.animDancaTrack:Stop(0); cd.animDancaTrack:Destroy(); cd.animDancaTrack = nil end
                    cd.dancando = false; cd.animAndarTrack = nil
                end
                -- Animação de andar
                if not cd.animAndarTrack then
                    local ad = ANIMS_ANDAR[animAndarAtual]
                    if ad then
                        local anim = Instance.new("Animation"); anim.AnimationId = ad.id
                        local a = cHum:FindFirstChildOfClass("Animator")
                        if a then
                            local tr = a:LoadAnimation(anim)
                            if tr then
                                tr.Looped = true; tr.Priority = Enum.AnimationPriority.Movement
                                tr:Play(0.3); cd.animAndarTrack = tr
                            end
                        end
                    end
                end
            end
            return
        end

        -- ============================================================
        -- SEGUINDO OUTRO PLAYER
        -- ============================================================
        local targetAlvo = cd.alvo or cloneAlvo
        if not targetAlvo then return end
        local tRoot = getRootPart(targetAlvo); if not tRoot then return end
        local distancia = (cRoot.Position - tRoot.Position).Magnitude

        local cloneAlvoParou = false
        if cd.alvoUltimaPos then
            local tv = Vector3.new(0,0,0)
            pcall(function() tv = tRoot.AssemblyLinearVelocity or tRoot.Velocity or Vector3.new(0,0,0) end)
            local dm = (Vector3.new(tRoot.Position.X,0,tRoot.Position.Z) - Vector3.new(cd.alvoUltimaPos.X,0,cd.alvoUltimaPos.Z)).Magnitude
            if Vector3.new(tv.X,0,tv.Z).Magnitude < 1 and dm < 0.3 then
                cd.alvoParadoTimer = cd.alvoParadoTimer + dt
                if cd.alvoParadoTimer >= alvoParadoThreshold then cloneAlvoParou = true end
            else cd.alvoParadoTimer = 0 end
        end
        cd.alvoUltimaPos = tRoot.Position

        if cloneDancar and cloneAlvoParou and distancia < cloneDistancia + 4 then
            if not cd.dancando then
                if cd.animAndarTrack then cd.animAndarTrack:Stop(0); cd.animAndarTrack = nil end
                pcall(function() local a = cHum:FindFirstChildOfClass("Animator"); if a then for _, t in pairs(a:GetPlayingAnimationTracks()) do t:Stop(0) end end end)
                local dd = DANCAS[animDancaAtual]
                if dd then
                    local anim = Instance.new("Animation"); anim.AnimationId = dd.id
                    local a = cHum:FindFirstChildOfClass("Animator")
                    if a then local tr = a:LoadAnimation(anim); if tr then tr.Looped=true; tr.Priority=Enum.AnimationPriority.Action4; tr:Play(0.1); cd.animDancaTrack=tr; cd.dancando=true end end
                end
            end
            cRoot.CFrame = CFrame.new(cRoot.Position, Vector3.new(tRoot.Position.X, cRoot.Position.Y, tRoot.Position.Z))
            return
        else
            if cd.dancando then
                if cd.animDancaTrack then cd.animDancaTrack:Stop(0); cd.animDancaTrack:Destroy(); cd.animDancaTrack = nil end
                cd.dancando = false; cd.animAndarTrack = nil
            end
        end

        if not cd.animAndarTrack and not cd.dancando then
            local ad = ANIMS_ANDAR[animAndarAtual]
            if ad then
                local anim = Instance.new("Animation"); anim.AnimationId = ad.id
                local a = cHum:FindFirstChildOfClass("Animator")
                if a then local tr = a:LoadAnimation(anim); if tr then tr.Looped=true; tr.Priority=Enum.AnimationPriority.Movement; tr:Play(0.3); cd.animAndarTrack=tr end end
            end
        end

        cHum.WalkSpeed = cloneVelocidade

        local tc = 0; local mi = 0
        for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then tc = tc + 1; if c == cd then mi = tc end end end
        if mi == 0 then mi = 1 end
        local ao = (mi / math.max(tc, 1)) * math.pi * 2
        local posNaRoda = tRoot.Position + Vector3.new(math.cos(ao) * cloneDistancia, 0, math.sin(ao) * cloneDistancia)

        if distancia > 80 then
            cRoot.CFrame = CFrame.new(tRoot.Position + Vector3.new(math.random()-0.5, 5, math.random()-0.5) * 10, tRoot.Position)
            return
        end
        if (cRoot.Position - posNaRoda).Magnitude < 3 then
            cRoot.CFrame = CFrame.new(cRoot.Position, Vector3.new(tRoot.Position.X, cRoot.Position.Y, tRoot.Position.Z))
            return
        end

        cHum:MoveTo(posNaRoda)
        cRoot.CFrame = CFrame.new(cRoot.Position, Vector3.new(tRoot.Position.X, cRoot.Position.Y, tRoot.Position.Z))
    end)

    table.insert(clonesAtivos, cd)
    addLog("Clone #" .. cid .. " CRIADO! Total: " .. #clonesAtivos .. " (" .. string.format("%.2f", tick()-t0) .. "s total)", "OK")
    return cd
end

local function removerClone(cd)
    pcall(function() if cd.conexao then cd.conexao:Disconnect(); cd.conexao=nil end end)
    pcall(function() if cd.modelo and cd.modelo.Parent then cd.modelo:Destroy() end end)
end
local function removerTodosClones()
    for _,cd in ipairs(clonesAtivos) do removerClone(cd) end; clonesAtivos={}
    if clonePasta then pcall(function() clonePasta:ClearAllChildren() end) end
    safeNotify("Clones","Todos removidos!")
end
local function getTotalClonesAtivos()
    local t=0; for _,cd in ipairs(clonesAtivos) do if cd.modelo and cd.modelo.Parent then t=t+1 end end; return t
end
local function adicionarClones(qtd, alvoPlayer)
    local ta = getTotalClonesAtivos()
    local who = alvoPlayer and (" -> " .. alvoPlayer.Name) or " (te seguem!)"
    addLog("=== Criando " .. qtd .. " clones" .. who .. " ===", "CLONE")
    safeNotify("Clones", "Criando " .. qtd .. "...")
    task.spawn(function()
        local criados = 0
        for i = 1, qtd do
            if criarCloneManual(alvoPlayer, ta + i, ta + qtd) then criados = criados + 1 end
            -- Sem delay entre clones - criar todos de uma vez
        end
        addLog("=== " .. criados .. "/" .. qtd .. " | Total: " .. getTotalClonesAtivos() .. " ===", "OK")
        safeNotify("Clones!", criados .. "/" .. qtd .. " | Total: " .. getTotalClonesAtivos())
    end)
end
local function redirecionarClones(novoAlvo)
    if not novoAlvo then return end
    for _,cd in ipairs(clonesAtivos) do
        cd.alvo = novoAlvo; cd.alvoIsMe = false
    end
    cloneAlvo = novoAlvo; cloneAlvoNome = novoAlvo.Name
    safeNotify("Redirecionados", getTotalClonesAtivos() .. " -> " .. novoAlvo.Name)
end

