local function desativarFantasma()
    if not fantasmaAtivo then return end; fantasmaAtivo=false
    pcall(function() local ch=LocalPlayer.Character; if not ch then return end; for n,w in pairs(fugirCollisionsBackup) do local part=ch:FindFirstChild(n); if part and part:IsA("BasePart") then part.CanCollide=w end end end)
    fugirCollisionsBackup={}
end
local function ativarFantasma()
    if fantasmaAtivo then return end; fantasmaAtivo=true; fantasmaTimer=FANTASMA_DURACAO; fugirCollisionsBackup={}
    pcall(function() local ch=LocalPlayer.Character; if not ch then return end; for _,part in pairs(ch:GetDescendants()) do if part:IsA("BasePart") then fugirCollisionsBackup[part.Name]=part.CanCollide; part.CanCollide=false end end end)
end
local function iniciarFugir(perseguidor)
    if not perseguidor then safeNotify("Erro","Selecione!"); return end
    if seguindo then pararSeguir() end; if conexaoFugir then conexaoFugir:Disconnect(); conexaoFugir=nil end
    playerPerseguidor=perseguidor; playerPerseguidorNome=perseguidor.Name; fugindo=true; inimigoPosAnterior=nil; fantasmaTimer=0; desativarFantasma()
    marcarPerseguidor(perseguidor); safeNotify("FUGINDO!",perseguidor.Name)
    conexaoFugir=RunService.Heartbeat:Connect(function(dt)
        if not fugindo or not playerPerseguidor then if conexaoFugir then conexaoFugir:Disconnect(); conexaoFugir=nil end; return end
        local mr=getRootPart(LocalPlayer); local mh=getHumanoid(LocalPlayer); local ir=getRootPart(playerPerseguidor)
        if not mr or not ir or not mh then return end
        local dist=(mr.Position-ir.Position).Magnitude
        local iv=Vector3.new(0,0,0); if inimigoPosAnterior then iv=(ir.Position-inimigoPosAnterior)/math.max(dt,0.001) end
        inimigoPosAnterior=ir.Position
        local speed=16
        if dist<3 then speed=300 elseif dist<fugirDistanciaMinima then speed=math.clamp(250-dist*20,150,250) elseif dist<15 then speed=math.clamp(150-dist*5,80,150) elseif dist<fugirDistanciaSegura then speed=math.clamp(80-dist,30,80) end
        mh.WalkSpeed=speed
        local dir=Vector3.new((mr.Position-ir.Position).X,0,(mr.Position-ir.Position).Z)
        if dir.Magnitude>0 then dir=dir.Unit else dir=Vector3.new(1,0,0) end
        if dist<fugirDistanciaSegura then mr.CFrame=CFrame.new(mr.Position+dir*3,mr.Position+dir*3-dir); if dist<10 then mh.Jump=true end end
    end)
end
local function pararFugir()
    fugindo=false; if conexaoFugir then conexaoFugir:Disconnect(); conexaoFugir=nil end; desativarFantasma(); limparHighlightPerseguidor()
    local h=getHumanoid(LocalPlayer); if h then h.WalkSpeed=speedAtivo and speedValor or walkSpeedOriginal end
    safeNotify("Parou!","Parou de fugir"); playerPerseguidor=nil
end
local function pararTudo()
    if seguindo then pararSeguir() end; if fugindo then pararFugir() end; if selecaoPorToque then desativarSelecaoPorToque() end
    setSpeed(false,16); pararTodasAnimacoes()
    pcall(function() if LocalPlayer.Character then for _,part in pairs(LocalPlayer.Character:GetDescendants()) do if part:IsA("BasePart") and part.Name~="HumanoidRootPart" then part.Transparency=0 elseif part:IsA("Decal") or part:IsA("Texture") then part.Transparency=0 end end end end)
