local function acharChao(posXZ, posYRef)
    local posY = posYRef or 100
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}
    pcall(function() if LocalPlayer.Character then table.insert(ignore, LocalPlayer.Character) end end)
    pcall(function() if clonePasta then table.insert(ignore, clonePasta) end end)
    rp.FilterDescendantsInstances = ignore
    local result = Workspace:Raycast(Vector3.new(posXZ.X, posY + 300, posXZ.Z), Vector3.new(0, -600, 0), rp)
    if result then return result.Position + Vector3.new(0, 3, 0) end
    return Vector3.new(posXZ.X, posY + 3, posXZ.Z)
end

-- ============================================================
-- CLONE SIMPLES: Clone() + limpar + Humanoid novo
-- ============================================================
local function criarClone(alvoPlayer, indice, total)
    addLog("Criando clone #" .. tostring(cloneContador + 1) .. "...", "CLONE")

    -- Pegar character atual (pode ter mudado)
    character = LocalPlayer.Character
    if not character then addLog("ERRO: Sem character", "ERRO"); return nil end
    meuRoot = character:FindFirstChild("HumanoidRootPart")
    if not meuRoot then addLog("ERRO: Sem HRP", "ERRO"); return nil end

    -- ============================================
    -- PASSO 1: CLONAR O CHARACTER INTEIRO
    -- Isso copia TUDO: Motor6D, acessorios, roupas, etc.
    -- ============================================
    local clone = nil
    local okClone, errClone = pcall(function()
        character.Archivable = true
        local c = character:Clone()
        character.Archivable = false
        return c
    end)

    if not okClone or not clone then
        addLog("ERRO ao clonar: " .. tostring(errClone), "ERRO")
        return nil
    end

    clone.Name = "DeltaClone_" .. tostring(cloneContador + 1)
    cloneContador = cloneContador + 1
    addLog("Character clonado: " .. clone.Name, "CLONE")

    -- ============================================
    -- PASSO 2: REMOVER COisas que nao precisamos
    -- ============================================
    for _, obj in pairs(clone:GetDescendants()) do
        if obj:IsA("LocalScript") or obj:IsA("Script") then
            obj:Destroy()
        elseif obj:IsA("Sound") then
            obj:Destroy()
        end
    end

    -- Remover scripts de nivel superior tambem
    for _, obj in pairs(clone:GetChildren()) do
        if obj:IsA("LocalScript") or obj:IsA("Script") then
            obj:Destroy()
        end
    end

    -- ============================================
    -- PASSO 3: REMOVER HUMANOID ANTIGO
    -- ============================================
    local oldHum = clone:FindFirstChildOfClass("Humanoid")
    if oldHum then oldHum:Destroy() end

    -- ============================================
    -- PASSO 4: CRIAR HUMANOID NOVO
    -- ============================================
    local newHum = Instance.new("Humanoid")
    newHum.MaxHealth = 99999
    newHum.Health = 99999
    newHum.WalkSpeed = cloneVelocidade
    newHum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    newHum.NameDisplayDistance = 0
    newHum.HealthDisplayDistance = 0
    newHum.BreakJointsOnDeath = false
    newHum.Parent = clone

    -- Copiar HipHeight do original
    pcall(function()
        local origHum = character:FindFirstChildOfClass("Humanoid")
        if origHum then newHum.HipHeight = origHum.HipHeight end
    end)

    -- Desabilitar estados de morte
    pcall(function()
        newHum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        newHum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        newHum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        newHum:ChangeState(Enum.HumanoidStateType.Running)
    end)

    addLog("Humanoid novo criado (Health=" .. newHum.MaxHealth .. " Speed=" .. cloneVelocidade .. ")", "CLONE")

    -- ============================================
    -- PASSO 5: GARANTIR HRP EXISTE
    -- ============================================
    local hrp = clone:FindFirstChild("HumanoidRootPart")
    if not hrp then
        -- Tentar achar qualquer parte para usar
        local firstPart = nil
        for _, obj in pairs(clone:GetChildren()) do
            if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then firstPart = obj; break end
        end
        if firstPart then
            hrp = Instance.new("Part")
            hrp.Name = "HumanoidRootPart"
            hrp.Size = Vector3.new(2, 2, 1)
            hrp.Transparency = 1
            hrp.CanCollide = false
            hrp.Parent = clone
        end
    end

    if hrp then clone.PrimaryPart = hrp end

    -- ============================================
    -- PASSO 6: CONFIGURAR PARTES
    -- ============================================
    for _, part in pairs(clone:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
            part.Anchored = false
        end
    end
    if hrp then hrp.CanCollide = false; hrp.Anchored = true end

    -- ============================================
    -- PASSO 7: POSICIONAR
    -- ============================================
    local angulo = (indice / math.max(total, 1)) * math.pi * 2
    local raio = math.random(5, cloneSpawnRaio)
    local spawnPos = acharChao(Vector3.new(
        meuRoot.Position.X + math.cos(angulo) * raio,
        0,
        meuRoot.Position.Z + math.sin(angulo) * raio
    ), meuRoot.Position.Y)

    -- Manter Y do player para nao cair
    local finalPos = Vector3.new(spawnPos.X, meuRoot.Position.Y, spawnPos.Z)
    if hrp then hrp.CFrame = CFrame.new(finalPos, alvoRoot.Position) end

    -- ============================================
    -- PASSO 8: CRIAR PASTA E PARENTAR
    -- ============================================
    if not clonePasta or not clonePasta.Parent then
        clonePasta = Instance.new("Folder")
        clonePasta.Name = "DELTA_CLONES"
        clonePasta.Parent = Workspace
    end

    clone.Parent = clonePasta
    addLog("Clone parentado no workspace!", "CLONE")

    -- ============================================
    -- PASSO 9: HIGHLIGHT
    -- ============================================
    local hl = Instance.new("Highlight")
    hl.Name = "DeltaCloneHL"
    hl.FillTransparency = 0.7
    hl.FillColor = Color3.fromRGB(0, 200, 255)
    hl.OutlineColor = Color3.fromRGB(0, 150, 255)
    hl.OutlineTransparency = 0
    hl.Parent = clone

    -- ============================================
    -- PASSO 10: DESANCORAR E ATIVAR
    -- ============================================
    local cd = {
        id = cloneContador,
        modelo = clone,
        conexao = nil,
        alvo = alvoPlayer,
        animAndarTrack = nil,
        animDancaTrack = nil,
        dancando = false,
        alvoUltimaPos = nil,
        alvoParadoTimer = 0,
        prontoPraAndar = false,
    }

    task.spawn(function()
        task.wait(1.0)
        if hrp and hrp.Parent then
            hrp.Anchored = false
            pcall(function() newHum:ChangeState(Enum.HumanoidStateType.Running) end)
            addLog("Clone #" .. cd.id .. " desancorado!", "OK")
        end
        task.wait(0.5)
        cd.prontoPraAndar = true
        addLog("Clone #" .. cd.id .. " PRONTO!", "OK")
    end)

    -- ============================================
    -- LOOP DO CLONE
    -- ============================================
    cd.conexao = RunService.Heartbeat:Connect(function(dt)
        if not cd.modelo or not cd.modelo.Parent then
            if cd.conexao then cd.conexao:Disconnect(); cd.conexao = nil end
            return
        end

        local cRoot = cd.modelo:FindFirstChild("HumanoidRootPart")
        local cHum = cd.modelo:FindFirstChildOfClass("Humanoid")
        if not cRoot or not cHum then return end

        -- Manter vivo
        if cHum.Health < cHum.MaxHealth then cHum.Health = cHum.MaxHealth end

        -- Estado Running
        pcall(function()
            local s = cHum:GetState()
            if s == Enum.HumanoidStateType.Dead or s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown then
                cHum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)

        if not cd.prontoPraAndar then return end

        local targetAlvo = cd.alvo or cloneAlvo
        if not targetAlvo then return end
        local tRoot = getRootPart(targetAlvo)
        if not tRoot then return end

        local dist = (cRoot.Position - tRoot.Position).Magnitude
        cHum.WalkSpeed = cloneVelocidade

        -- Detectar alvo parado
        local alvoParou = false
        if cd.alvoUltimaPos then
            local dm = (Vector3.new(tRoot.Position.X, 0, tRoot.Position.Z) - Vector3.new(cd.alvoUltimaPos.X, 0, cd.alvoUltimaPos.Z)).Magnitude
            local tv = Vector3.new(0, 0, 0)
            pcall(function() tv = tRoot.AssemblyLinearVelocity or tRoot.Velocity or Vector3.new(0, 0, 0) end)
            local tvH = Vector3.new(tv.X, 0, tv.Z).Magnitude
            local th = targetAlvo.Character and targetAlvo.Character:FindFirstChildOfClass("Humanoid")
            local tm = th and th.MoveDirection.Magnitude > 0.1
            if tvH < 1 and dm < 0.3 and not tm then
                cd.alvoParadoTimer = cd.alvoParadoTimer + dt
                if cd.alvoParadoTimer >= alvoParadoThreshold then alvoParou = true end
            else cd.alvoParadoTimer = 0 end
        end
        cd.alvoUltimaPos = tRoot.Position

        -- Danca se alvo parou
        if cloneDancar and alvoParou and dist < cloneDistancia + 4 then
            if not cd.dancando then
                if cd.animAndarTrack then pcall(function() cd.animAndarTrack:Stop(0) end); cd.animAndarTrack = nil end
                local dancaData = DANCAS[animDancaAtual]
                if dancaData then
                    local anim = Instance.new("Animation"); anim.AnimationId = dancaData.id
                    local animator = cHum:FindFirstChildOfClass("Animator")
                    if animator then
                        local ok, track = pcall(function() return animator:LoadAnimation(anim) end)
                        if ok and track then track.Looped = true; track.Priority = Enum.AnimationPriority.Action4; track:Play(0.1); cd.animDancaTrack = track; cd.dancando = true end
                    end
                end
            end
            pcall(function() cRoot.CFrame = CFrame.new(cRoot.Position, Vector3.new(tRoot.Position.X, cRoot.Position.Y, tRoot.Position.Z)) end)
            return
        else
            if cd.dancando then
                if cd.animDancaTrack then pcall(function() cd.animDancaTrack:Stop(0); cd.animDancaTrack:Destroy() end); cd.animDancaTrack = nil end
                cd.dancando = false; cd.animAndarTrack = nil
            end
        end

        -- Animacao de andar
        if not cd.animAndarTrack and not cd.dancando then
            local ad = ANIMS_ANDAR[animAndarAtual]
            if ad then
                local anim = Instance.new("Animation"); anim.AnimationId = ad.id
                local animator = cHum:FindFirstChildOfClass("Animator")
                if animator then
                    local ok, track = pcall(function() return animator:LoadAnimation(anim) end)
                    if ok and track then track.Looped = true; track.Priority = Enum.AnimationPriority.Movement; track:Play(0.3); cd.animAndarTrack = track end
                end
            end
        end

        -- Se muito longe, teleportar
        if dist > 80 then
            local centro = getRootPart(LocalPlayer) or tRoot
            local tpPos = acharChao(Vector3.new(
                centro.Position.X + math.cos(math.random() * math.pi * 2) * math.random(5, 15),
                0,
                centro.Position.Z + math.sin(math.random() * math.pi * 2) * math.random(5, 15)
            ), centro.Position.Y)
            cRoot.CFrame = CFrame.new(tpPos, tRoot.Position)
            return
        end

        -- Mover para alvo (formacao em roda)
        local totalClones = 0; local myIdx = 0
        for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then totalClones = totalClones + 1; if c == cd then myIdx = totalClones end end end
        if myIdx == 0 then myIdx = 1 end

        local angOff = (myIdx / math.max(totalClones, 1)) * math.pi * 2
        local posAlvo = tRoot.Position + Vector3.new(math.cos(angOff) * cloneDistancia, 0, math.sin(angOff) * cloneDistancia)

        if dist < cloneDistancia + 3 then
            -- Perto: so olhar
            pcall(function() cRoot.CFrame = CFrame.new(cRoot.Position, Vector3.new(tRoot.Position.X, cRoot.Position.Y, tRoot.Position.Z)) end)
        else
            cHum:MoveTo(posAlvo)
        end
    end)

    -- Calcular indice na roda
    local totalAtual = 0
    for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then totalAtual = totalAtual + 1 end end
    cd.indiceRoda = totalAtual + 1

    table.insert(clonesAtivos, cd)
    addLog("Clone #" .. cd.id .. " CRIADO! Total: " .. #clonesAtivos, "OK")
    return cd
end

local function removerClone(cd)
    pcall(function() if cd.conexao then cd.conexao:Disconnect(); cd.conexao = nil end end)
    pcall(function() if cd.modelo and cd.modelo.Parent then cd.modelo:Destroy() end end)
end

local function removerTodosClones()
    for _, cd in ipairs(clonesAtivos) do removerClone(cd) end
    clonesAtivos = {}
    if clonePasta then pcall(function() for _, c in pairs(clonePasta:GetChildren()) do c:Destroy() end end) end
    addLog("Todos clones removidos", "OK"); safeNotify("Clones", "Todos removidos!")
end

local function getTotalClonesAtivos()
    local t = 0; for _, cd in ipairs(clonesAtivos) do if cd.modelo and cd.modelo.Parent then t = t + 1 end end; return t
end

local function adicionarClones(qtd, alvoPlayer)
    if not alvoPlayer then safeNotify("Erro", "Selecione alvo!"); return end
    if not getRootPart(alvoPlayer) then safeNotify("Erro", alvoPlayer.Name .. " sem personagem!"); return end
    cloneAlvo = alvoPlayer; cloneAlvoNome = alvoPlayer.Name
    local totalAntes = getTotalClonesAtivos()
    safeNotify("Clones", "Criando " .. qtd .. " clones...")
    task.spawn(function()
        local criados = 0
        for i = 1, qtd do
            task.wait(0.3)
            if criarClone(alvoPlayer, totalAntes + i, totalAntes + qtd) then criados = criados + 1 end
        end
        safeNotify("Clones Criados!", criados .. "/" .. qtd .. " | Total: " .. getTotalClonesAtivos())
    end)
end

local function redirecionarClones(novoAlvo)
    if not novoAlvo then return end
    cloneAlvo = novoAlvo; cloneAlvoNome = novoAlvo.Name
    for _, cd in ipairs(clonesAtivos) do cd.alvo = novoAlvo end
    safeNotify("Redirecionados", getTotalClonesAtivos() .. " -> " .. novoAlvo.Name)
end

