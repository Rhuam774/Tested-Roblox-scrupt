    task.wait(2)
    local l = getListaPlayers()
    for _, d in ipairs({"DropSeguir", "DropTP", "DropFugir", "DropCloneAlvo"}) do pcall(function() local f = Rayfield.Flags; if f and f[d] then f[d]:Refresh(l) end end) end
end)

LocalPlayer.CharacterAdded:Connect(function()
    animSentadoTrack = nil; animAndarTrack = nil; animDancaTrack = nil; estaDancando = false
    desativarFantasma()
    task.wait(2)
    character = LocalPlayer.Character
    meuRoot = character and character:FindFirstChild("HumanoidRootPart")
    meuHum = character and character:FindFirstChildOfClass("Humanoid")
    if meuHum then walkSpeedOriginal = meuHum.WalkSpeed end
    if seguindo then if playerAlvo and getRootPart(playerAlvo) then iniciarSeguir(playerAlvo) else pararSeguir() end end
    if fugindo then if playerPerseguidor and getRootPart(playerPerseguidor) then iniciarFugir(playerPerseguidor) else pararFugir() end end
    if speedAtivo and not fugindo then if meuHum then meuHum.WalkSpeed = speedValor end end
end)

