local function iniciarSeguir(alvo)
    if not alvo then safeNotify("Erro","Sem player!"); return end
    if not getRootPart(alvo) then safeNotify("Erro",alvo.Name.." sem char!"); return end
    if fugindo then fugindo=false; if conexaoFugir then conexaoFugir:Disconnect(); conexaoFugir=nil end; limparHighlightPerseguidor() end
    pararTodasAnimacoes(); limparHighlightSelecionado(); dancaCancelada=false
    local mh=getHumanoid(LocalPlayer); if mh and not speedAtivo then walkSpeedOriginal=mh.WalkSpeed end
    playerAlvo=alvo; seguindo=true
    alvoUltimaPos=nil; alvoParadoTimer=0; alvoEstaParado=false; estaDancando=false; meuPersonagemPerto=false
    safeNotify("Seguindo!",alvo.Name)
    if conexaoSeguir then conexaoSeguir:Disconnect(); conexaoSeguir=nil end
    conexaoSeguir=RunService.Heartbeat:Connect(function(dt)
        if not seguindo or not playerAlvo then if conexaoSeguir then conexaoSeguir:Disconnect(); conexaoSeguir=nil end; return end
        local mr=getRootPart(LocalPlayer); local mh=getHumanoid(LocalPlayer); local tr=getRootPart(playerAlvo)
        if not mr or not tr or not mh then return end
        if speedAtivo then mh.WalkSpeed=speedValor end
        local tv=Vector3.new(0,0,0); pcall(function() tv=tr.AssemblyLinearVelocity or tr.Velocity or Vector3.new(0,0,0) end)
        local tvh=Vector3.new(tv.X,0,tv.Z).Magnitude
        local th=playerAlvo.Character and playerAlvo.Character:FindFirstChildOfClass("Humanoid")
        local tm=th and th.MoveDirection.Magnitude>0.1
        local parado=(tvh<1) and (not alvoUltimaPos or (Vector3.new(tr.Position.X,0,tr.Position.Z)-Vector3.new(alvoUltimaPos.X,0,alvoUltimaPos.Z)).Magnitude<0.3) and (not tm)
        if parado then alvoParadoTimer=alvoParadoTimer+dt; if alvoParadoTimer>=alvoParadoThreshold then alvoEstaParado=true end
        else alvoParadoTimer=0; alvoEstaParado=false end
        alvoUltimaPos=tr.Position
        local dist=(mr.Position-tr.Position).Magnitude; meuPersonagemPerto=dist<=(distanciaSeguir+3)
        if alvoEstaParado and meuPersonagemPerto and dancarAoParar then if not estaDancando then pararAnimsMovimento(); task.spawn(function() iniciarDanca(false) end) end
        else if estaDancando then pararDanca(); animAndarTrack=nil end end
        local lookDir=tr.CFrame.LookVector; local posAtras=tr.Position-(lookDir*distanciaSeguir)
        if not estaDancando then iniciarAnimAndar() end
        if dist>60 then mr.CFrame=CFrame.new(posAtras,tr.Position)
        elseif alvoEstaParado and dist<distanciaSeguir+3 then mr.CFrame=CFrame.new(mr.Position,Vector3.new(tr.Position.X,mr.Position.Y,tr.Position.Z))
        else mh:MoveTo(posAtras) end
        if modoInvisivel then pcall(function() if LocalPlayer.Character then for _,part in pairs(LocalPlayer.Character:GetDescendants()) do if part:IsA("BasePart") then part.Transparency=1 elseif part:IsA("Decal") or part:IsA("Texture") then part.Transparency=1 end end end end) end
    end)
end
