local LogBuffer = {}
local MAX_LOGS = 500
local logLabelRef = nil

local function addLog(msg, tipo)
    tipo = tipo or "INFO"
    local timeStr = os and os.date and os.date("%H:%M:%S") or "??:??:??"
    table.insert(LogBuffer, "[" .. timeStr .. "] [" .. tipo .. "] " .. tostring(msg))
    if #LogBuffer > MAX_LOGS then table.remove(LogBuffer, 1) end
    if logLabelRef and logLabelRef.Parent then
        pcall(function()
            logLabelRef.Text = table.concat(LogBuffer, "\n")
            logLabelRef.TextSize = 13
            local p = logLabelRef.Parent
            if p:IsA("ScrollingFrame") then
                p.CanvasSize = UDim2.new(0, 0, 0, logLabelRef.TextBounds.Y + 40)
                p.CanvasPosition = Vector2.new(0, math.max(0, logLabelRef.TextBounds.Y - p.AbsoluteSize.Y + 40))
            end
        end)
    end
end

