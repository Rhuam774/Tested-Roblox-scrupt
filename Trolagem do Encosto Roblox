end

local function getPlayerByName(nome)
    if not nome or nome == "" then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Name:lower() == nome:lower() then return p end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Name:lower():find(nome:lower(), 1, true) then return p end
    end
    return nil
end

