    local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}
    pcall(function() if LocalPlayer.Character then table.insert(ignore, LocalPlayer.Character) end end)
    pcall(function() if clonePasta then table.insert(ignore, clonePasta) end end)
    rp.FilterDescendantsInstances = ignore
    local result = Workspace:Raycast(origem, Vector3.new(0, -500, 0), rp)
    if result then return result.Position.Y + 3 end
    return (refY or 50)
end

-- ============================================================
-- CRIAR CLONE - CRIA DO ZERO COM MOTOR6D
-- ============================================================
local function criarCloneManual(alvoPlayer, indice, totalNovos)
    local character = LocalPlayer.Character
    if not character then addLog("ERRO: Sem character!", "ERRO"); return nil end
    local meuRoot = character:FindFirstChild("HumanoidRootPart")
    if not meuRoot then addLog("ERRO: Sem HRP!", "ERRO"); return nil end
    local alvoRoot = getRootPart(alvoPlayer)
    if not alvoRoot then addLog("ERRO: Alvo sem HRP!", "ERRO"); return nil end

    -- Copiar cores do character original
    local bodyColors = character:FindFirstChildOfClass("BodyColors")
    local skinColor = Color3.fromRGB(230, 200, 175)
    local headColor = skinColor
    local torsoColor = Color3.fromRGB(0, 162, 255)
    local larmColor = skinColor
    local rarmColor = skinColor
    local llegColor = Color3.fromRGB(0, 25, 200)
    local rlegColor = Color3.fromRGB(0, 25, 200)
    if bodyColors then
        pcall(function() headColor = bodyColors.HeadColor end)
        pcall(function() torsoColor = bodyColors.TorsoColor end)
        pcall(function() larmColor = bodyColors.LeftArmColor end)
        pcall(function() rarmColor = bodyColors.RightArmColor end)
        pcall(function() llegColor = bodyColors.LeftLegColor end)
        pcall(function() rlegColor = bodyColors.RightLegColor end)
    end
    -- Also check for shirt/pants colors
    local shirt = character:FindFirstChildOfClass("Shirt")
    local pants = character:FindFirstChildOfClass("Pants")

    cloneContador = cloneContador + 1
    addLog("Criando clone #" .. cloneContador .. " (do zero)...", "CLONE")

    local model = Instance.new("Model")
    model.Name = "DeltaClone_" .. cloneContador

    -- ============================================================
    -- FUNCAO AUXILIAR: criar parte
    -- ============================================================
    local function makePart(name, size, color, parent)
        local p = Instance.new("Part")
        p.Name = name; p.Size = size; p.Color = color
        p.Material = Enum.Material.SmoothPlastic
        p.TopSurface = Enum.SurfaceType.Smooth
        p.BottomSurface = Enum.SurfaceType.Smooth
        p.CanCollide = true; p.Anchored = true; p.Parent = parent
        return p
    end

    -- ============================================================
    -- FUNCAO AUXILIAR: criar Motor6D
    -- ============================================================
    local function makeMotor(name, part0, part1, c0, c1)
        local m = Instance.new("Motor6D")
        m.Name = name; m.Part0 = part0; m.Part1 = part1
        m.C0 = c0; m.C1 = c1; m.Parent = part1
        return m
    end

    -- ============================================================
    -- HUMANOIDROOTPART
    -- ============================================================
    local hrp = makePart("HumanoidRootPart", Vector3.new(2, 2, 1), Color3.new(0.5, 0.5, 0.5), model)
    hrp.Transparency = 1; hrp.CanCollide = false

    -- ============================================================
    -- R15 BODY PARTS (proporcoes padrao Roblox)
    -- ============================================================
    local lt = makePart("LowerTorso", Vector3.new(2, 2, 1), torsoColor, model)
    local ut = makePart("UpperTorso", Vector3.new(2, 2, 1), torsoColor, model)
    local hd = makePart("Head", Vector3.new(2, 1, 1), headColor, model)
    hd.Shape = Enum.PartType.Ball

    local rua = makePart("RightUpperArm", Vector3.new(1, 2, 1), rarmColor, model)
    local rla = makePart("RightLowerArm", Vector3.new(1, 2, 1), rarmColor, model)
    local rh = makePart("RightHand", Vector3.new(1, 1, 2), rarmColor, model)

    local lua = makePart("LeftUpperArm", Vector3.new(1, 2, 1), larmColor, model)
    local lla = makePart("LeftLowerArm", Vector3.new(1, 2, 1), larmColor, model)
    local lh = makePart("LeftHand", Vector3.new(1, 1, 2), larmColor, model)

    local rul = makePart("RightUpperLeg", Vector3.new(1, 2, 1), rlegColor, model)
    local rll = makePart("RightLowerLeg", Vector3.new(1, 2, 1), rlegColor, model)
    local rf = makePart("RightFoot", Vector3.new(1, 1, 2), rlegColor, model)

    local lul = makePart("LeftUpperLeg", Vector3.new(1, 2, 1), llegColor, model)
    local lll = makePart("LeftLowerLeg", Vector3.new(1, 2, 1), llegColor, model)
    local lf = makePart("LeftFoot", Vector3.new(1, 1, 2), llegColor, model)

    -- ============================================================
    -- MOTOR6D JOINTS (estrutura R15)
    -- ============================================================
    -- HRP -> LowerTorso (Raiz)
    makeMotor("Root", hrp, lt,
        CFrame.new(0, 0, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, -0.5, 0) * CFrame.Angles(0, 0, 0))

    -- LowerTorso -> UpperTorso (Coluna)
    makeMotor("Waist", lt, ut,
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0))

    -- UpperTorso -> Head (Pescoco)
    makeMotor("Neck", ut, hd,
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, -0.5, 0) * CFrame.Angles(0, 0, 0))

    -- Braco Direito
    makeMotor("RightShoulder", ut, rua,
        CFrame.new(1.5, 0.5, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(-0.5, 0.5, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("RightElbow", rua, rla,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("RightWrist", rla, rh,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 0.5, 0) * CFrame.Angles(0, 0, 0))

    -- Braco Esquerdo
    makeMotor("LeftShoulder", ut, lua,
        CFrame.new(-1.5, 0.5, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0.5, 0.5, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("LeftElbow", lua, lla,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("LeftWrist", lla, lh,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 0.5, 0) * CFrame.Angles(0, 0, 0))

    -- Perna Direita
    makeMotor("RightHip", lt, rul,
        CFrame.new(0.5, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("RightKnee", rul, rll,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("RightAnkle", rll, rf,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 0.5, 0) * CFrame.Angles(0, 0, 0))

    -- Perna Esquerda
    makeMotor("LeftHip", lt, lul,
        CFrame.new(-0.5, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("LeftKnee", lul, lll,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 1, 0) * CFrame.Angles(0, 0, 0))
    makeMotor("LeftAnkle", lll, lf,
        CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0),
        CFrame.new(0, 0.5, 0) * CFrame.Angles(0, 0, 0))

    addLog("  15 partes + 13 Motor6D criados", "CLONE")

    -- ============================================================
    -- HUMANOID
    -- ============================================================
    local hum = Instance.new("Humanoid")
    hum.MaxHealth = 99999; hum.Health = 99999
    hum.WalkSpeed = cloneVelocidade
    hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    hum.NameDisplayDistance = 0; hum.HealthDisplayDistance = 0
    hum.BreakJointsOnDeath = false
    hum.Parent = model

    pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false) end)
    pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end)
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)

    -- Animator
    local animator = Instance.new("Animator")
    animator.Parent = hum

    -- PrimaryPart
    model.PrimaryPart = hrp

    -- Roupa (copiar shirt/pants se existir)
    pcall(function() if shirt then local s=shirt:Clone(); s.Parent=model end end)
    pcall(function() if pants then local p2=pants:Clone(); p2.Parent=model end end)

    -- ============================================================
    -- POSICIONAR
    -- ============================================================
    local angulo = (indice / math.max(totalNovos, 1)) * math.pi * 2
    local raio = math.random(8, cloneSpawnRaio)
    local spawnX = meuRoot.Position.X + math.cos(angulo) * raio
    local spawnZ = meuRoot.Position.Z + math.sin(angulo) * raio
    local groundY = acharChao(spawnX, spawnZ, meuRoot.Position.Y)

    -- Calcular posicao: HRP fica a 0.5 do chao
    -- Pernas vao de -4 (topo da coxa) a -1 (pe)
    -- HRP = chao + 4.5
    local hrpY = groundY + 4.5
    local hrpPos = Vector3.new(spawnX, hrpY, spawnZ)

    hrp.CFrame = CFrame.new(hrpPos, Vector3.new(alvoRoot.Position.X, hrpY, alvoRoot.Position.Z))

    addLog("  HRP em Y=" .. string.format("%.1f", hrpY) .. " (chao em Y=" .. string.format("%.1f", groundY) .. ")", "CLONE")

    -- ============================================================
    -- PASTA DE CLONES
    -- ============================================================
    if not clonePasta or not clonePasta.Parent then
        clonePasta = Instance.new("Folder")
        clonePasta.Name = "DELTA_CLONES"
        clonePasta.Parent = Workspace
    end

    -- Parentar (importante: parentar DEPOIS de posicionar)
    model.Parent = clonePasta
    addLog("  Clone #" .. cloneContador .. " parentado no Workspace!", "CLONE")

    -- ============================================================
    -- HIGHLIGHT
    -- ============================================================
    pcall(function()
        local hl = Instance.new("Highlight")
        hl.Name = "DeltaCloneHL"
        hl.FillTransparency = 0.7
        hl.FillColor = Color3.fromRGB(0, 200, 255)
        hl.OutlineColor = Color3.fromRGB(0, 150, 255)
        hl.OutlineTransparency = 0
        hl.Parent = model
    end)

    -- ============================================================
    -- DESANCORAR APOS DELAY
    -- ============================================================
    local cd = {
        id = cloneContador, modelo = model, conexao = nil,
        indiceRoda = 0, alvo = alvoPlayer,
        animAndarTrack = nil, animDancaTrack = nil, dancando = false,
        alvoUltimaPos = nil, alvoParadoTimer = 0, alvoEstaParado = false,
        prontoPraAndar = false,
        waypoints = {}, waypointIndex = 1, pathTimer = 0, ultimaPosAlvo = nil,
    }

    task.spawn(function()
        task.wait(0.5)
        -- Desancorar tudo
        for _, part in pairs(model:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                part.CanCollide = true
            end
        end
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)
        addLog("  Clone #" .. cd.id .. " desancorado!", "OK")
        task.wait(0.5)
        cd.prontoPraAndar = true
        addLog("Clone #" .. cd.id .. " PRONTO E ANDANDO!", "OK")
    end)

    -- Indice na roda
    local totalAtual = 0
    for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then totalAtual = totalAtual + 1 end end
    cd.indiceRoda = totalAtual + 1

    -- ============================================================
    -- LOOP IA
    -- ============================================================
    cd.conexao = RunService.Heartbeat:Connect(function(dt)
        if not cd.modelo or not cd.modelo.Parent then
            if cd.conexao then cd.conexao:Disconnect(); cd.conexao = nil end; return
        end
        local cRoot = cd.modelo:FindFirstChild("HumanoidRootPart")
        local cHum = cd.modelo:FindFirstChildOfClass("Humanoid")
        if not cRoot or not cHum then return end
        if cHum.Health < cHum.MaxHealth then cHum.Health = cHum.MaxHealth end
        pcall(function() local s=cHum:GetState(); if s==Enum.HumanoidStateType.Dead or s==Enum.HumanoidStateType.Ragdoll then cHum:ChangeState(Enum.HumanoidStateType.Running) end end)
        if not cd.prontoPraAndar then return end

        local targetAlvo = cd.alvo or cloneAlvo
        if not targetAlvo then return end
        local tRoot = getRootPart(targetAlvo); if not tRoot then return end
        local distancia = (cRoot.Position - tRoot.Position).Magnitude

        -- Alvo parou?
        local cloneAlvoParou = false
        if cd.alvoUltimaPos then
            local dm = (Vector3.new(tRoot.Position.X,0,tRoot.Position.Z)-Vector3.new(cd.alvoUltimaPos.X,0,cd.alvoUltimaPos.Z)).Magnitude
            local tv=Vector3.new(0,0,0); pcall(function() tv=tRoot.AssemblyLinearVelocity or tRoot.Velocity or Vector3.new(0,0,0) end)
            if Vector3.new(tv.X,0,tv.Z).Magnitude<1 and dm<0.3 then cd.alvoParadoTimer=cd.alvoParadoTimer+dt; if cd.alvoParadoTimer>=alvoParadoThreshold then cloneAlvoParou=true end
            else cd.alvoParadoTimer=0 end
        end
        cd.alvoUltimaPos=tRoot.Position

        -- Danca
        if cloneDancar and cloneAlvoParou and distancia<cloneDistancia+4 then
            if not cd.dancando then
                if cd.animAndarTrack then pcall(function() cd.animAndarTrack:Stop(0) end); cd.animAndarTrack=nil end
                pcall(function() local a=cHum:FindFirstChildOfClass("Animator"); if a then for _,t in pairs(a:GetPlayingAnimationTracks()) do pcall(function() t:Stop(0) end) end end end)
                local dd=DANCAS[animDancaAtual]
                if dd then local anim=Instance.new("Animation"); anim.AnimationId=dd.id; local a=cHum:FindFirstChildOfClass("Animator")
                    if a then local ok,tr=pcall(function() return a:LoadAnimation(anim) end); if ok and tr then tr.Looped=true; tr.Priority=Enum.AnimationPriority.Action4; tr:Play(0.1); cd.animDancaTrack=tr; cd.dancando=true end end end
            end
            pcall(function() cRoot.CFrame=CFrame.new(cRoot.Position,Vector3.new(tRoot.Position.X,cRoot.Position.Y,tRoot.Position.Z)) end)
            return
        else if cd.dancando then pcall(function() if cd.animDancaTrack then cd.animDancaTrack:Stop(0); cd.animDancaTrack:Destroy() end end); cd.animDancaTrack=nil; cd.dancando=false; cd.animAndarTrack=nil end end

        -- Andar anim
        if not cd.animAndarTrack and not cd.dancando then
            local ad=ANIMS_ANDAR[animAndarAtual]
            if ad then local anim=Instance.new("Animation"); anim.AnimationId=ad.id; local a=cHum:FindFirstChildOfClass("Animator")
                if a then local ok,tr=pcall(function() return a:LoadAnimation(anim) end); if ok and tr then tr.Looped=true; tr.Priority=Enum.AnimationPriority.Movement; tr:Play(0.3); cd.animAndarTrack=tr end end end
        end

        cHum.WalkSpeed=cloneVelocidade

        -- Roda
        local tc=0; local mi=0
        for _,c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then tc=tc+1; if c==cd then mi=tc end end end
        if mi==0 then mi=1 end
        local ao=(mi/math.max(tc,1))*math.pi*2
        local posNaRoda=tRoot.Position+Vector3.new(math.cos(ao)*cloneDistancia,0,math.sin(ao)*cloneDistancia)

        if distancia>80 then local cr=getRootPart(LocalPlayer) or tRoot; local tp=acharChao(cr.Position.X+math.cos(math.random()*math.pi*2)*10,cr.Position.Z+math.sin(math.random()*math.pi*2)*10,cr.Position.Y)
            cRoot.CFrame=CFrame.new(Vector3.new(tp.X,tp.Y+4.5,tp.Z),tRoot.Position); cd.waypoints={}; cd.waypointIndex=1; cd.ultimaPosAlvo=nil; return end
        if (cRoot.Position-posNaRoda).Magnitude<3 then pcall(function() cRoot.CFrame=CFrame.new(cRoot.Position,Vector3.new(tRoot.Position.X,cRoot.Position.Y,tRoot.Position.Z)) end); return end

        cd.pathTimer=cd.pathTimer+dt
        local pr=cd.ultimaPosAlvo==nil or (tRoot.Position-cd.ultimaPosAlvo).Magnitude>10 or cd.pathTimer>1.5 or #cd.waypoints==0
        if pr then cd.pathTimer=0; cd.ultimaPosAlvo=tRoot.Position; local rota=calcularPath(cRoot.Position,posNaRoda)
            if rota then cd.waypoints=rota; cd.waypointIndex=1 else pcall(function() cHum:MoveTo(posNaRoda) end); return end end
        if #cd.waypoints>0 and cd.waypointIndex<=#cd.waypoints then local wp=cd.waypoints[cd.waypointIndex]; if wp.Action==Enum.PathWaypointAction.Jump then cHum.Jump=true end; pcall(function() cHum:MoveTo(wp.Position) end); if (cRoot.Position-wp.Position).Magnitude<4 then cd.waypointIndex=cd.waypointIndex+1 end
        else pcall(function() cHum:MoveTo(posNaRoda) end) end
    end)

    table.insert(clonesAtivos, cd)
    addLog("Clone #" .. cd.id .. " CRIADO! Total: " .. #clonesAtivos, "OK")
    return cd
end

local function removerClone(cd)
    pcall(function() if cd.conexao then cd.conexao:Disconnect(); cd.conexao=nil end end)
    pcall(function() if cd.animAndarTrack then cd.animAndarTrack:Stop(0) end end)
    pcall(function() if cd.animDancaTrack then cd.animDancaTrack:Stop(0); cd.animDancaTrack:Destroy() end end)
    pcall(function() if cd.modelo and cd.modelo.Parent then cd.modelo:Destroy() end end)
end
local function removerTodosClones()
    for _,cd in ipairs(clonesAtivos) do removerClone(cd) end; clonesAtivos={}
    if clonePasta then pcall(function() clonePasta:ClearAllChildren() end) end
    safeNotify("Clones","Todos removidos!")
end
local function getTotalClonesAtivos()
    local t=0; for _,cd in ipairs(clonesAtivos) do if cd.modelo and cd.modelo.Parent then t=t+1 end end; return t
end
local function adicionarClones(qtd,alvoPlayer)
    if not alvoPlayer then safeNotify("Erro","Selecione alvo!"); return end
    if not getRootPart(alvoPlayer) then safeNotify("Erro",alvoPlayer.Name.." sem personagem!"); return end
    cloneAlvo=alvoPlayer; cloneAlvoNome=alvoPlayer.Name; local ta=getTotalClonesAtivos()
    safeNotify("Clones","Criando "..qtd.." clones...")
    task.spawn(function()
        local criados=0
        for i=1,qtd do task.wait(0.3); if criarCloneManual(alvoPlayer,ta+i,ta+qtd) then criados=criados+1 end end
        safeNotify("Clones!",criados.."/"..qtd.." | Total: "..getTotalClonesAtivos())
    end)
end
local function redirecionarClones(novoAlvo)
    if not novoAlvo then return end; cloneAlvo=novoAlvo; cloneAlvoNome=novoAlvo.Name
    for _,cd in ipairs(clonesAtivos) do cd.alvo=novoAlvo; cd.waypoints={}; cd.waypointIndex=1; cd.ultimaPosAlvo=nil; cd.pathTimer=99 end
    safeNotify("Redirecionados",getTotalClonesAtivos().." -> "..novoAlvo.Name)
end

