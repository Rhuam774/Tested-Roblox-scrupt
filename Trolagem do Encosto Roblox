    if not alvoRoot then safeNotify("Erro", alvo.Name .. " sem personagem!"); return end
    if fugindo then fugindo = false; if conexaoFugir then conexaoFugir:Disconnect(); conexaoFugir = nil end; limparHighlightPerseguidor() end
    pararTodasAnimacoes(); limparHighlightSelecionado(); dancaCancelada = false
    local meuHumanoid = getHumanoid(LocalPlayer)
    if meuHumanoid and not speedAtivo then walkSpeedOriginal = meuHumanoid.WalkSpeed end
    playerAlvo = alvo; playerAlvoNome = alvo.Name; seguindo = true
    waypoints = {}; waypointIndex = 1; ultimaPosAlvo = nil; pathRecalcTimer = 0
    alvoUltimaPos = nil; alvoParadoTimer = 0; alvoEstaParado = false; estaDancando = false; meuPersonagemPerto = false
