local function acharChao(posXZ, posYRef)
    local origem = Vector3.new(posXZ.X, (posYRef or 100) + 300, posXZ.Z)
    local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}; pcall(function() if LocalPlayer.Character then table.insert(ignore, LocalPlayer.Character) end end)
    pcall(function() if clonePasta then table.insert(ignore, clonePasta) end end)
    rp.FilterDescendantsInstances = ignore
    local result = Workspace:Raycast(origem, Vector3.new(0, -600, 0), rp)
    if result then return result.Position + Vector3.new(0, 3, 0) end
    return Vector3.new(posXZ.X, (posYRef or 100) + 3, posXZ.Z)
end

-- ============================================================
-- CRIAR CLONE - SIMPLES E DIRETO (character:Clone())
-- ============================================================
local function criarCloneManual(alvoPlayer, indice, totalNovos)
    local character = LocalPlayer.Character
    if not character then addLog("ERRO: Sem character!", "ERRO"); return nil end
    local meuRoot = character:FindFirstChild("HumanoidRootPart")
    if not meuRoot then addLog("ERRO: Sem HumanoidRootPart!", "ERRO"); return nil end
    local alvoRoot = getRootPart(alvoPlayer)
    if not alvoRoot then addLog("ERRO: Alvo sem HRP!", "ERRO"); return nil end

    cloneContador = cloneContador + 1
    addLog("Criando clone #" .. cloneContador .. " com Clone()...", "CLONE")

    -- ====================================
    -- CLONAR CHARACTER INTEIRO DE UMA VEZ
    -- Isso copia TUDO: Motor6Ds, acessorios,
    -- roupas, body colors, decals, tudo.
    -- ====================================
    local ok, cloneModel = pcall(function() return character:Clone() end)

    if not ok or not cloneModel then
        addLog("ERRO Clone(): " .. tostring(cloneModel), "ERRO")
        cloneContador = cloneContador - 1
        return nil
    end

    cloneModel.Name = "DeltaClone_" .. cloneContador

    -- Remover PlayerGui do clone (nao precisa)
    pcall(function() local pg = cloneModel:FindFirstChild("PlayerGui"); if pg then pg:Destroy() end end)

    -- Remover qualquer Script/LocalScript do clone
    for _, obj in pairs(cloneModel:GetDescendants()) do
        if obj:IsA("Script") or obj:IsA("LocalScript") then
            pcall(function() obj:Destroy() end)
        end
    end

    -- Verificar se tem Humanoid
    local cloneHum = cloneModel:FindFirstChildOfClass("Humanoid")
    if not cloneHum then
        addLog("ERRO: Clone sem Humanoid!", "ERRO")
        pcall(function() cloneModel:Destroy() end)
        cloneContador = cloneContador - 1
        return nil
    end

    -- Configurar Humanoid
    cloneHum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    cloneHum.NameDisplayDistance = 0
    cloneHum.HealthDisplayDistance = 0
    cloneHum.MaxHealth = 99999
    cloneHum.Health = 99999
    cloneHum.BreakJointsOnDeath = false
    cloneHum.WalkSpeed = cloneVelocidade
    pcall(function() cloneHum:SetStateEnabled(Enum.HumanoidStateType.Dead, false) end)
    pcall(function() cloneHum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end)
    pcall(function() cloneHum:ChangeState(Enum.HumanoidStateType.Running) end)

    -- Garir animator
    if not cloneHum:FindFirstChildOfClass("Animator") then
        Instance.new("Animator").Parent = cloneHum
    end

    -- PrimaryPart
    local hrp = cloneModel:FindFirstChild("HumanoidRootPart")
    if hrp then cloneModel.PrimaryPart = hrp end

    -- Pasta de clones
    if not clonePasta or not clonePasta.Parent then
        clonePasta = Instance.new("Folder")
        clonePasta.Name = "DELTA_CLONES"
        clonePasta.Parent = Workspace
    end

    -- Posicionar
    local angulo = (indice / math.max(totalNovos, 1)) * math.pi * 2
    local raio = math.random(8, cloneSpawnRaio)
    local spawnXZ = Vector3.new(meuRoot.Position.X + math.cos(angulo) * raio, 0, meuRoot.Position.Z + math.sin(angulo) * raio)
    local spawnPos = acharChao(spawnXZ, meuRoot.Position.Y)

    if hrp then
        local finalPos = Vector3.new(spawnPos.X, meuRoot.Position.Y, spawnPos.Z)
        hrp.CFrame = CFrame.new(finalPos, alvoRoot.Position)
    end

    -- Parentar no workspace
    cloneModel.Parent = clonePasta

    addLog("Clone #" .. cloneContador .. " parentado! Aguardando physics...", "CLONE")

    -- Aguardar e desancorar
    local cd = {
        id = cloneContador,
        modelo = cloneModel,
        conexao = nil,
        indiceRoda = 0,
        alvo = alvoPlayer,
        animAndarTrack = nil,
        animDancaTrack = nil,
        dancando = false,
        alvoUltimaPos = nil,
        alvoParadoTimer = 0,
        alvoEstaParado = false,
        prontoPraAndar = false,
        waypoints = {},
        waypointIndex = 1,
        pathTimer = 0,
        ultimaPosAlvo = nil,
    }

    task.spawn(function()
        task.wait(1.0)
        -- Desancorar todas as partes
        for _, part in pairs(cloneModel:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                part.CanCollide = true
            end
        end
        -- Forcar estado Running
        pcall(function() cloneHum:ChangeState(Enum.HumanoidStateType.Running) end)
        addLog("Clone #" .. cd.id .. " desancorado!", "OK")

        task.wait(0.5)
        cd.prontoPraAndar = true
        addLog("Clone #" .. cd.id .. " PRONTO!", "OK")
    end)

    -- Highlight
    pcall(function()
        local hl = Instance.new("Highlight")
        hl.Name = "DeltaCloneHL"
        hl.FillTransparency = 0.7
        hl.FillColor = Color3.fromRGB(0, 200, 255)
        hl.OutlineColor = Color3.fromRGB(0, 150, 255)
        hl.OutlineTransparency = 0
        hl.Parent = cloneModel
    end)

    -- Calcular indice na roda
    local totalAtual = 0
    for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then totalAtual = totalAtual + 1 end end
    cd.indiceRoda = totalAtual + 1

    -- ============================================================
    -- LOOP IA DO CLONE
    -- ============================================================
    cd.conexao = RunService.Heartbeat:Connect(function(dt)
        if not cd.modelo or not cd.modelo.Parent then
            if cd.conexao then cd.conexao:Disconnect(); cd.conexao = nil end
            return
        end

        local cRoot = cd.modelo:FindFirstChild("HumanoidRootPart")
        local cHum = cd.modelo:FindFirstChildOfClass("Humanoid")
        if not cRoot or not cHum then return end

        -- Manter vivo
        if cHum.Health < cHum.MaxHealth then cHum.Health = cHum.MaxHealth end
        pcall(function()
            local s = cHum:GetState()
            if s == Enum.HumanoidStateType.Dead or s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown then
                cHum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)

        if not cd.prontoPraAndar then return end

        local targetAlvo = cd.alvo or cloneAlvo
        if not targetAlvo then return end
        local tRoot = getRootPart(targetAlvo)
        if not tRoot then return end

        local distancia = (cRoot.Position - tRoot.Position).Magnitude

        -- Detectar alvo parado
        local cloneAlvoParou = false
        if cd.alvoUltimaPos then
            local dm = (Vector3.new(tRoot.Position.X, 0, tRoot.Position.Z) - Vector3.new(cd.alvoUltimaPos.X, 0, cd.alvoUltimaPos.Z)).Magnitude
            local tv = Vector3.new(0,0,0); pcall(function() tv = tRoot.AssemblyLinearVelocity or tRoot.Velocity or Vector3.new(0,0,0) end)
            local tvh = Vector3.new(tv.X, 0, tv.Z).Magnitude
            local th = targetAlvo.Character and targetAlvo.Character:FindFirstChildOfClass("Humanoid")
            local tm = th and th.MoveDirection.Magnitude > 0.1
            if tvh < 1 and dm < 0.3 and not tm then cd.alvoParadoTimer = cd.alvoParadoTimer + dt; if cd.alvoParadoTimer >= alvoParadoThreshold then cloneAlvoParou = true end
            else cd.alvoParadoTimer = 0 end
        end
        cd.alvoUltimaPos = tRoot.Position

        -- DANCA
        if cloneDancar and cloneAlvoParou and distancia < cloneDistancia + 4 then
            if not cd.dancando then
                if cd.animAndarTrack then pcall(function() cd.animAndarTrack:Stop(0) end); cd.animAndarTrack = nil end
                pcall(function() local a = cHum:FindFirstChildOfClass("Animator"); if a then for _, t in pairs(a:GetPlayingAnimationTracks()) do pcall(function() t:Stop(0) end) end end end)
                local dd = DANCAS[animDancaAtual]
                if dd then
                    local anim = Instance.new("Animation"); anim.AnimationId = dd.id
                    local a = cHum:FindFirstChildOfClass("Animator")
                    if a then local ok2, track = pcall(function() return a:LoadAnimation(anim) end)
                        if ok2 and track then track.Looped = true; track.Priority = Enum.AnimationPriority.Action4; track:Play(0.1); cd.animDancaTrack = track; cd.dancando = true end end
                end
            end
            pcall(function() cRoot.CFrame = CFrame.new(cRoot.Position, Vector3.new(tRoot.Position.X, cRoot.Position.Y, tRoot.Position.Z)) end)
            return
        else
            if cd.dancando then pcall(function() if cd.animDancaTrack then cd.animDancaTrack:Stop(0); cd.animDancaTrack:Destroy() end end); cd.animDancaTrack = nil; cd.dancando = false; cd.animAndarTrack = nil end
        end

        -- ANIMACAO ANDAR
        if not cd.animAndarTrack and not cd.dancando then
            local ad = ANIMS_ANDAR[animAndarAtual]
            if ad then local anim = Instance.new("Animation"); anim.AnimationId = ad.id
                local a = cHum:FindFirstChildOfClass("Animator")
                if a then local ok2, track = pcall(function() return a:LoadAnimation(anim) end)
                    if ok2 and track then track.Looped = true; track.Priority = Enum.AnimationPriority.Movement; track:Play(0.3); cd.animAndarTrack = track end end end
        end

        cHum.WalkSpeed = cloneVelocidade

        -- INDICE NA RODA
        local tc = 0; local mi = 0
        for _, c in ipairs(clonesAtivos) do if c.modelo and c.modelo.Parent then tc = tc + 1; if c == cd then mi = tc end end end
        if mi == 0 then mi = 1 end
        local ao = (mi / math.max(tc, 1)) * math.pi * 2
        local posNaRoda = tRoot.Position + Vector3.new(math.cos(ao) * cloneDistancia, 0, math.sin(ao) * cloneDistancia)

        -- TP se longe
        if distancia > 80 then
            local cr = getRootPart(LocalPlayer) or tRoot
            local tp = acharChao(Vector3.new(cr.Position.X + math.cos(math.random()*math.pi*2)*math.random(5,15), 0, cr.Position.Z + math.sin(math.random()*math.pi*2)*math.random(5,15)), cr.Position.Y)
            cRoot.CFrame = CFrame.new(tp, tRoot.Position)
            cd.waypoints = {}; cd.waypointIndex = 1; cd.ultimaPosAlvo = nil; return
        end

        -- Perto da roda
        if (cRoot.Position - posNaRoda).Magnitude < 3 then
            pcall(function() cRoot.CFrame = CFrame.new(cRoot.Position, Vector3.new(tRoot.Position.X, cRoot.Position.Y, tRoot.Position.Z)) end)
            return
        end

        -- PATHFINDING
        cd.pathTimer = cd.pathTimer + dt
        local pr = false
        if cd.ultimaPosAlvo == nil then pr = true
        elseif (tRoot.Position - cd.ultimaPosAlvo).Magnitude > 10 then pr = true
        elseif cd.pathTimer > 1.5 then pr = true
        elseif #cd.waypoints == 0 then pr = true end

        if pr then
            cd.pathTimer = 0; cd.ultimaPosAlvo = tRoot.Position
            local rota = calcularPath(cRoot.Position, posNaRoda)
            if rota then cd.waypoints = rota; cd.waypointIndex = 1
            else pcall(function() cHum:MoveTo(posNaRoda) end); return end
        end

        if #cd.waypoints > 0 and cd.waypointIndex <= #cd.waypoints then
            local wp = cd.waypoints[cd.waypointIndex]
            if wp.Action == Enum.PathWaypointAction.Jump then cHum.Jump = true end
            pcall(function() cHum:MoveTo(wp.Position) end)
            if (cRoot.Position - wp.Position).Magnitude < 4 then cd.waypointIndex = cd.waypointIndex + 1 end
        else
            pcall(function() cHum:MoveTo(posNaRoda) end)
        end
    end)

    table.insert(clonesAtivos, cd)
    addLog("Clone #" .. cd.id .. " CRIADO! Total: " .. #clonesAtivos, "OK")
    return cd
end

local function removerClone(cd)
    pcall(function() if cd.conexao then cd.conexao:Disconnect(); cd.conexao = nil end end)
    pcall(function() if cd.animAndarTrack then cd.animAndarTrack:Stop(0) end end)
    pcall(function() if cd.animDancaTrack then cd.animDancaTrack:Stop(0); cd.animDancaTrack:Destroy() end end)
    pcall(function() if cd.modelo and cd.modelo.Parent then cd.modelo:Destroy() end end)
end

local function removerTodosClones()
    for _, cd in ipairs(clonesAtivos) do removerClone(cd) end
    clonesAtivos = {}
    if clonePasta then pcall(function() clonePasta:ClearAllChildren() end) end
    addLog("Todos clones removidos!", "OK"); safeNotify("Clones", "Todos removidos!")
end

local function getTotalClonesAtivos()
    local t = 0; for _, cd in ipairs(clonesAtivos) do if cd.modelo and cd.modelo.Parent then t = t + 1 end end; return t
end

local function adicionarClones(qtd, alvoPlayer)
    if not alvoPlayer then safeNotify("Erro", "Selecione alvo!"); return end
    if not getRootPart(alvoPlayer) then safeNotify("Erro", alvoPlayer.Name .. " sem personagem!"); return end
    cloneAlvo = alvoPlayer; cloneAlvoNome = alvoPlayer.Name
    local ta = getTotalClonesAtivos()
    addLog("Criando " .. qtd .. " clones...", "CLONE"); safeNotify("Clones", "Criando " .. qtd .. " clones...")
    task.spawn(function()
        local criados = 0
        for i = 1, qtd do task.wait(0.5)
            if criarCloneManual(alvoPlayer, ta + i, ta + qtd) then criados = criados + 1 end
        end
        safeNotify("Clones Criados!", criados .. "/" .. qtd .. " | Total: " .. getTotalClonesAtivos())
    end)
end

local function redirecionarClones(novoAlvo)
    if not novoAlvo then return end; cloneAlvo = novoAlvo; cloneAlvoNome = novoAlvo.Name
    for _, cd in ipairs(clonesAtivos) do cd.alvo = novoAlvo; cd.waypoints = {}; cd.waypointIndex = 1; cd.ultimaPosAlvo = nil; cd.pathTimer = 99 end
    safeNotify("Redirecionados", getTotalClonesAtivos() .. " clones -> " .. novoAlvo.Name)
end

