-- ============================================================
-- CARREGAR RAYFIELD COM FALLBACK DE URLs
-- ============================================================
local Rayfield = nil
local RayfieldLoadTime = 0

do
    local urls = {
        'https://sirius.menu/rayfield',
        'https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua',
    }

    for idx, url in ipairs(urls) do
        addLog("Tentando URL " .. idx .. ": " .. url, "INFO")
        local startTime = tick()

        local httpOk, httpResult = pcall(function()
            return game:HttpGet(url)
        end)

        if not httpOk then
            addLog("HttpGet falhou na URL " .. idx .. ": " .. tostring(httpResult), "WARN")
        else
            if not httpResult or #httpResult < 100 then
                addLog("Resposta muito curta na URL " .. idx .. " (" .. tostring(httpResult and #httpResult or 0) .. " bytes)", "WARN")
            else
                addLog("HttpGet OK! " .. #httpResult .. " bytes", "OK")
                local loadOk, loadResult = pcall(function()
                    return loadstring(httpResult)()
                end)

                RayfieldLoadTime = tick() - startTime

                if loadOk and loadResult then
                    Rayfield = loadResult
                    addLog("Rayfield carregado da URL " .. idx .. " em " .. string.format("%.2f", RayfieldLoadTime) .. "s", "OK")
                    break
                else
                    addLog("loadstring falhou na URL " .. idx .. ": " .. tostring(loadResult), "WARN")
                end
            end
        end
    end

    if not Rayfield then
        addLog("ERRO CRITICO: Nenhuma URL funcionou para carregar Rayfield!", "ERRO")
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Delta v10.2 - ERRO",
                Text = "Falha ao carregar Rayfield - Verifique sua internet/executor",
                Duration = 15
            })
        end)
        return
    end
end

