local function iniciarFugir(perseguidor)
    if not perseguidor then safeNotify("Erro","Selecione de quem fugir!"); return end
    if seguindo then pararSeguir() end
    if conexaoFugir then conexaoFugir:Disconnect(); conexaoFugir=nil end
    playerPerseguidor=perseguidor; playerPerseguidorNome=perseguidor.Name; fugindo=true
    inimigoPosAnterior=nil; fugirMemoriaPosicoes={}; fugirMemoriaTimer=0; fugirJukeTimer=0; desativarFantasma()
    marcarPerseguidor(perseguidor); safeNotify("FUGINDO!",perseguidor.Name)
    conexaoFugir=RunService.Heartbeat:Connect(function(dt)
        if not fugindo or not playerPerseguidor then if conexaoFugir then conexaoFugir:Disconnect(); conexaoFugir=nil end; return end
        local mr=getRootPart(LocalPlayer); local mh=getHumanoid(LocalPlayer); local ir=getRootPart(playerPerseguidor)
        if not mr or not ir or not mh then return end
        local dist=(mr.Position-ir.Position).Magnitude
        local iv=Vector3.new(0,0,0); if inimigoPosAnterior then iv=(ir.Position-inimigoPosAnterior)/math.max(dt,0.001) end
        inimigoPosAnterior=ir.Position; local ip=ir.Position+iv*0.5
        fugirMemoriaTimer=fugirMemoriaTimer+dt
        if fugirMemoriaTimer>=0.5 then fugirMemoriaTimer=0; table.insert(fugirMemoriaPosicoes,mr.Position); if #fugirMemoriaPosicoes>20 then table.remove(fugirMemoriaPosicoes,1) end end
        if fantasmaAtivo then fantasmaTimer=fantasmaTimer-dt; if fantasmaTimer<=0 then desativarFantasma() end end
        local speed=16
        if dist<3 then speed=300 elseif dist<fugirDistanciaMinima then speed=math.clamp(250-dist*20,150,250) elseif dist<15 then speed=math.clamp(150-dist*5,80,150) elseif dist<fugirDistanciaSegura then speed=math.clamp(80-dist,30,80) end
        mh.WalkSpeed=speed
        local dirFuga=Vector3.new((mr.Position-ip).X,0,(mr.Position-ip).Z)
        if dirFuga.Magnitude>0 then dirFuga=dirFuga.Unit else dirFuga=Vector3.new(1,0,0) end
        local novaPos=mr.Position+dirFuga*3
        if dist<fugirDistanciaSegura then mr.CFrame=CFrame.new(novaPos,novaPos-dirFuga); if dist<10 then mh.Jump=true end end
    end)
end
