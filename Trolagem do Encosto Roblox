        if seguindo then return end
        local mr = getRootPart(LocalPlayer); if not mr then return end
        for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then local r = getRootPart(p); if r and (mr.Position - r.Position).Magnitude < 5 then safeNotify("Toque!", "Encostou em " .. p.Name); iniciarSeguir(p); break end end end
