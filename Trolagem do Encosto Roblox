    if #LogBuffer > MAX_LOGS then table.remove(LogBuffer, 1) end
    print(entry)
    if logLabelRef and logLabelRef.Parent then
        pcall(function()
            logLabelRef.Text = table.concat(LogBuffer, "\n")
